{
  "name": "assistencialize",
  "version": "1.0.0",
  "description": "Meu App Multi WhatsApp",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "author": "Seu Nome",
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "latest"
  },
  "build": {
    "appId": "com.seu-nome.assistencialize",
    "productName": "Assistencialize",
    "files": [
      "main.js",
      "index.html",
      "renderer.js",
      "styles.css",
      "icon.png"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.png"
    }
  },
  "dependencies": {
    "electron-updater": "^6.7.3"
  }
}
